{
  "title": "Ride Saga Overview",
  "uid": "ride-saga-overview",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Events consumed per topic (msg/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (name) (rate(spring_kafka_listener_seconds_count[1m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Listener processing latency p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, name) (rate(spring_kafka_listener_seconds_bucket[5m])))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dead-lettered messages",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(dlq_messages_total) or vector(0)" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Duplicate events skipped",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(events_duplicate_total) or vector(0)" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Notifications sent",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(notifications_sent_total) or vector(0)" }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Drivers available",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(drivers_available)" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP requests booking-service (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{job=\"ride-saga-services\"}[1m]))",
          "legendFormat": "{{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "JVM heap used (MiB)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\"}) / 1024 / 1024",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ]
}
